{
  "name": "titanium-dashboard",
  "version": "1.0.0",
  "description": "Titanium Dashboard is a modern, cross-platform stock tracking dashboard",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Marketionist/titanium-dashboard"
  },
  "keywords": [
    "titanium dashboard",
    "titanium-dashboard",
    "Titanium Dashboard",
    "Titanium-Dashboard"
  ],
  "author": "Dmytro Shpakovskyi",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:mac": "tsc && vite build && electron-builder --mac",
    "build:win": "tsc && vite build && electron-builder --win",
    "install:all": "npm install --legacy-peer-deps",
    "lint": "eslint .",
    "preview": "vite preview",
    "patch": "npm version patch -m \"Bump up package version to %s\" && git push && git push origin --tags && npm publish",
    "minor": "npm version minor -m \"Bump up package version to %s\" && git push && git push origin --tags && npm publish",
    "major": "npm version major -m \"Bump up package version to %s\" && git push && git push origin --tags && npm publish"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "41.1.1",
    "electron-builder": "^26.8.2",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "main": "dist-electron/main.js"
}
